{
  "name": "honor",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:all": "concurrently -k -n NEXT,DB,SB -c cyan,magenta,yellow \"pnpm dev\" \"pnpm db:studio\" \"pnpm storybook\"",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:pull": "drizzle-kit pull",
    "db:update": "pnpm db:generate && pnpm db:migrate && pnpm db:push",
    "db:reset": "rm ./dev.db && rm -r ./src/db/migrations && pnpm db:update",
    "auth:generate": "pnpx @better-auth/cli generate --config ./src/lib/auth.ts --output ./src/db/schema/auth.ts -y",
    "db:auth": "pnpm auth:generate && pnpm db:update",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
